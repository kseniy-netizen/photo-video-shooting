APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Vercel (Settings → Environment Variables). После деплоя APP_URL = ваш *.vercel.app
# APP_KEY=base64:...  (php artisan key:generate --show)
# APP_ENV=production
# APP_DEBUG=false
# CACHE_DRIVER=array
# SESSION_DRIVER=cookie
# LOG_CHANNEL=stderr
# VIEW_COMPILED_PATH=/tmp/framework/views
# DB_* — облачная PostgreSQL (Neon, Supabase и т.д.), не localhost
# Картинки из БД: положите файлы в public/storage/ (как после php artisan storage:link)
# API сайта: /data/* (не /api — папка api/ на Vercel занята PHP-функцией)

# Для robots.txt (Host) и sitemap.xml укажите реальный домен, например https://luxury-shoot.ru
SEO_SITE_NAME=Luxury Shoot

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=photo_video
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Docker (docker compose --profile local-db up)
# DB_HOST=db
# DB_PORT=5432
# DB_DATABASE=photo_video
# DB_USERNAME=postgres
# DB_PASSWORD=postgres
# APP_URL=http://localhost:8080
# APP_PORT=8080

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
